# ═══════════════════════════════════════════════════════════════════════════════
# 워터닉스 IoT 시스템 - 환경변수 예시 파일
# 이 파일을 복사하여 .env로 이름을 변경하고 값을 설정하세요
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ─── 앱 설정 ──────────────────────────────────────────────────────────────────
APP_NAME=워터닉스 IoT 관리 시스템
APP_VERSION=1.0.0
DEBUG=false

# ─── 보안 (운영환경에서 반드시 강력한 값으로 변경!) ─────────────────────────────
SECRET_KEY=your-very-secret-key-minimum-32-characters-long

# ─── 데이터베이스 (PostgreSQL + TimescaleDB) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://waternix:your_db_password@localhost:5432/waternix_db

# ─── Redis 캐시/세션 ────────────────────────────────────────────────────────────
REDIS_URL=redis://:your_redis_password@localhost:6379/0

# ─── MQTT 브로커 (Eclipse Mosquitto) ────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_ENABLED=false
MQTT_TOPIC_PREFIX=waternix

# ─── 산업용 통신 설정 ───────────────────────────────────────────────────────────
# Modbus
MODBUS_TIMEOUT=3.0
MODBUS_RETRIES=3
MODBUS_POLL_INTERVAL=5.0

# 시리얼 (RS485/RS232) 기본값
SERIAL_BAUDRATE=19200
SERIAL_BYTESIZE=8
SERIAL_PARITY=N
SERIAL_STOPBITS=1
SERIAL_TIMEOUT=1.0

# ─── 알림 임계값 ────────────────────────────────────────────────────────────────
ALERT_TDS_WARNING=20
ALERT_TDS_CRITICAL=50
ALERT_REJECTION_WARNING=95.0
ALERT_REJECTION_CRITICAL=90.0
ALERT_PRESSURE_MAX=12.0
ALERT_OFFLINE_WARNING_MIN=5
ALERT_OFFLINE_CRITICAL_MIN=30
ALERT_FILTER_WARNING_PCT=80
ALERT_FILTER_CRITICAL_PCT=95

# ─── CORS (허용 오리진) ─────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ─── 이메일 알림 (SendGrid) ─────────────────────────────────────────────────────
# SENDGRID_API_KEY=SG.xxxxxxxx
# ALERT_EMAIL_FROM=noreply@waternix.com
# ALERT_EMAIL_TO=admin@waternix.com

# ─── SMS 알림 (AWS SNS) ─────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-northeast-2
# ALERT_SMS_TO=+821012345678
